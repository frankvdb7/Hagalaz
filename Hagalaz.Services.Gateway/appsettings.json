{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "authorization": {
        "ClusterId": "authorization",
        "Match": {
          "Path": "/rdx/authorization/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/rdx/authorization/" }
        ]
      },
      "characters": {
        "ClusterId": "characters",
        "Match": {
          "Path": "/rdx/characters/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/rdx/characters" }
        ]
      },
      "cache": {
        "ClusterId": "cache",
        "Match": {
          "Path": "/rdx/cache/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/rdx/cache" }
        ]
      }
    },
    "Clusters": {
      "authorization": {
        "Destinations": {
          "authorization": {
            "Address": "http://hagalaz-services-authorization",
            "Health": "http://hagalaz-services-authorization/health"
          }
        }
      },
      "characters": {
        "Destinations": {
          "characters": {
            "Address": "http://hagalaz-services-characters",
            "Health": "http://hagalaz-services-characters/health"
          }
        }
      },
      "cache": {
        "Destinations": {
          "cache": {
            "Address": "http://hagalaz-services-cache",
            "Health": "http://hagalaz-services-cache/health"
          }
        }
      }
    }
  }
}
